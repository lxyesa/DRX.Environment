# SMTP settings for email verification (local development)
KAX_SMTP_EMAIL=your_qq_email@qq.com
KAX_SMTP_AUTH_CODE=eymlrhwykskccbdb
KAX_SMTP_HOST=smtp.qq.com
KAX_SMTP_PORT=587
KAX_SMTP_ENABLE_SSL=true

# JWT settings for authentication (required in production)
KAX_JWT_SECRET_KEY=replace_with_a_strong_random_secret
KAX_JWT_ISSUER=KaxSocket
KAX_JWT_AUDIENCE=KaxUsers
KAX_JWT_EXPIRATION_DAYS=7
