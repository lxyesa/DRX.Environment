  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Environments\SDK\Drx.Sdk.Shared.JavaScript\Drx.Sdk.Shared.JavaScript.csproj" />
    <ProjectReference Include="..\..\..\Environments\SDK\Drx.Sdk.Shared\Drx.Sdk.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Models\**\*.js">
